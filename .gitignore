dist/
build/
target/
*.js.map
*.css.map

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Coverage
coverage/
htmlcov/
.coverage

# OS generated files
.DS_Store
Thumbs.db
```