```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Logs and temp files
*.log
*.tmp
*.swp

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```